# Shippabel — client environment variables (Vite)
# Copy to .env and fill in. These are exposed to the browser, so only use
# public/anon values here. Secrets (Stripe secret, Anthropic, EAS, service role)
# live in Supabase Edge Function secrets — never in this file.

# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (publishable key only on the client; plan->price mapping is server-side)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...

# --- Edge Function secrets (set with `supabase secrets set`, NOT here) ---
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...        # from the Stripe webhook endpoint
# STRIPE_PRICE_SHIP=price_...            # optional; create-checkout falls back to a built-in ID
# STRIPE_PRICE_UNLIMITED=price_...       # optional; create-checkout falls back to a built-in ID
# ANTHROPIC_API_KEY=sk-ant-...
# EAS_ACCESS_TOKEN=...
# CREDENTIALS_ENC_KEY=...                # base64 of 32 random bytes; encrypts user_credentials at rest
# BUILD_CALLBACK_SECRET=...              # shared secret the build workflow sends to build-complete
# SUPABASE_SERVICE_ROLE_KEY=...          # auto-provided in Edge Functions
